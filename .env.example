# Denaro Trading Bot — Environment Configuration
# Copia questo file in .env e inserisci le tue chiavi reali

# Machine label: mc2 | nuvola | MARCODG1
MACHINE_LABEL=mc2

# Binance API Keys (formato: BINANCE_API_KEY_<MACHINE_LABEL>)
BINANCE_API_KEY_mc2=YOUR_API_KEY_HERE
BINANCE_API_SECRET_mc2=YOUR_SECRET_KEY_HERE

BINANCE_API_KEY_nuvola=YOUR_API_KEY_HERE
BINANCE_API_SECRET_nuvola=YOUR_SECRET_KEY_HERE

BINANCE_API_KEY_MARCODG1=YOUR_API_KEY_HERE
BINANCE_API_SECRET_MARCODG1=YOUR_SECRET_KEY_HERE

# Telegram alerts
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Min trade size in EUR
NOTIONAL_MIN=5.0

# Binance Key Prefix (SUB1/SUB2/SUB3 — DEPRECATED, usare MACHINE_LABEL)
# BINANCE_KEY_PREFIX=SUB1
